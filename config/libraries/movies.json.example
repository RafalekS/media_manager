{
  "enabled": true,
  "name": "Movies",
  "media_type": "movies",
  "source_folder": "",
  "destination_base": "",
  "organize_enabled": true,
  "scan_mode": "folders",
  "file_extensions": [
    ".mkv",
    ".mp4",
    ".avi",
    ".m4v"
  ],
  "data_folder": "data/movies",
  "primary_provider": "tmdb",
  "supplement_providers": [
    "omdb",
    "trakt"
  ],
  "genre_file": "config/libraries/movies_genres.json",
  "html_filename": "movies_database_dynamic.html",
  "items_per_page": 50,
  "bat_output_path": "",
  "rate_limit": 0.25,
  "api": {
    "tmdb_api_key": "",
    "omdb_api_key": "",
    "trakt_client_id": ""
  }
}