{
  "enabled": true,
  "name": "Books",
  "media_type": "books",
  "source_folder": "",
  "destination_base": "",
  "organize_enabled": false,
  "scan_mode": "files",
  "scan_depth": 1,
  "file_extensions": [
    ".epub",
    ".pdf",
    ".mobi",
    ".azw3",
    ".azw"
  ],
  "data_folder": "data/books",
  "primary_provider": "google_books",
  "supplement_providers": [
    "open_library",
    "internet_archive"
  ],
  "genre_file": "config/libraries/books_genres.json",
  "html_filename": "books_database_dynamic.html",
  "items_per_page": 50,
  "bat_output_path": "",
  "rate_limit": 0.25,
  "api": {
    "google_books_api_key": ""
  }
}