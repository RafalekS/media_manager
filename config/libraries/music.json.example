{
  "enabled": true,
  "name": "Music",
  "media_type": "music",
  "source_folder": "",
  "destination_base": "",
  "organize_enabled": false,
  "scan_mode": "folders",
  "file_extensions": [
    ".mp3",
    ".flac",
    ".m4a",
    ".ogg",
    ".wav",
    ".aac"
  ],
  "data_folder": "data/music",
  "primary_provider": "musicbrainz",
  "supplement_providers": [
    "lastfm",
    "discogs"
  ],
  "genre_file": "config/libraries/music_genres.json",
  "html_filename": "music_database_dynamic.html",
  "items_per_page": 50,
  "bat_output_path": "",
  "rate_limit": 1.1,
  "api": {
    "lastfm_api_key": "",
    "discogs_token": ""
  }
}